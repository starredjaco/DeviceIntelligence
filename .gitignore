# Built application files
*.apk
*.aar
*.ap_
*.aab
*.idsig

# Files for the ART/Dalvik VM
*.dex
# Exception: the CTF Flag 1 payload is the source of truth for the
# DEX-injection red-team harnesses (LSPosed module bakes it into a
# generated Kotlin source via the bakeFlag1Payload Gradle task).
# Regenerated by tools/red-team/flag1-payload/build-payload.sh.
!tools/red-team/flag1-payload/payload.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
.kotlin/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml

# Keystore files
*.jks
# Sample's deliberately-fake attacker keystore is checked in so the
# "farm-resigned" demo APK can be regenerated without the user
# fabricating their own keystore. Password is documented in
# dist/README.md.
!samples/minimal/keystore/fake.jks
*.keystore

