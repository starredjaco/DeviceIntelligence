<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        ACCESS_NETWORK_STATE is intentionally NOT declared here even
        though DeviceContext.vpnActive needs it.

        Consumers opt in per-app via the deviceintelligence Gradle
        DSL block:

            deviceintelligence {
                enableVpnDetection.set(true)
            }

        which makes the plugin inject the permission into the
        consumer's variant manifest. Apps that don't opt in ship
        without ACCESS_NETWORK_STATE and DeviceContext.vpnActive
        reports `null`, which is graceful degradation.

        Why opt-in even though the permission is `normal`-protection
        and Play-store benign: the value the field carries (whether
        the user is on a VPN) is privacy-sensitive enough that we
        want each consumer to consciously decide they want it
        rather than inheriting it silently from a transitive library.
    -->

    <!--
        Broad package visibility for runtime.root.

        IMPORTANT FOR CONSUMERS: this is a Google-Play-restricted
        permission. Apps that include this manifest will inherit it
        through manifest merging; when those apps are submitted to
        Google Play, the developer must justify the permission under
        one of the Play Console permitted use cases
        (https://support.google.com/googleplay/android-developer/answer/10158779).
        "Anti-malware / security app" is the relevant category for
        DeviceIntelligence-driven integrity telemetry. Consumers who
        cannot justify the permission should remove it via a
        manifest-merger override:

            <uses-permission
                android:name="android.permission.QUERY_ALL_PACKAGES"
                tools:node="remove" />

        runtime.root will then fall back to whatever subset of packages
        the consumer's own <queries> block exposes (or just to the
        on-disk / shell signals).

        Why we declare it at the library level: Android 11+ hides
        installed packages from getPackageInfo() / getInstalledPackages()
        unless the caller declares either an explicit <queries> entry,
        a matching <queries><intent>, or this permission. runtime.root needs
        to enumerate beyond a hand-maintained list (new root managers
        appear constantly — KernelSU forks, Apatch, etc.) and the
        permission is the only mechanism that gives that scope.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!--
        INTERNET is required for the native analytics layer (dicore) to
        deliver device-hardware telemetry events to Firebase Measurement
        Protocol. All HTTP calls are fire-and-forget from a background
        pthread; analytics can be disabled via the Gradle DSL:
            deviceintelligence { disableAnalytics.set(true) }
        INTERNET is a normal-protection permission (no runtime prompt,
        no Play Store sensitive-permission review). Most apps that use
        this SDK will already declare it for their own network usage;
        in that case the manifest merger produces no duplicate.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:appComponentFactory="io.ssemaj.deviceintelligence.internal.DeviceIntelligenceComponentFactory"
        tools:targetApi="28">
        <!--
            Earliest-possible bootstrap for libdicore. AGP manifest
            merger uses standard precedence here: a consumer that
            already declares `android:appComponentFactory` on its own
            <application> wins (their value beats ours, no conflict
            raised) and we silently fall back to the ContentProvider
            below. A consumer that has none inherits ours, which
            triggers System.loadLibrary("dicore") inside
            `instantiateApplication()` — that runs BEFORE the
            Application instance is even constructed and BEFORE
            ContentProviders attach, giving native_integrity's
            JNI_OnLoad baseline the earliest possible snapshot of
            the process.

            tools:targetApi="28" silences the lint warning;
            android:appComponentFactory is honoured only on API 28+
            and silently ignored on older devices, where the
            ContentProvider remains the bootstrap path.
        -->

        <!--
            ContentProvider bootstrap fallback. Always present, so
            even on API 27 / on consumers that overrode the
            appComponentFactory, libdicore still loads before
            Application.onCreate and the prewarm collect kicks off.

            initOrder is Integer.MAX_VALUE so we beat every other
            ContentProvider in the merged manifest (AndroidX Startup
            uses 10000, Firebase ~100, WorkManager ~200; ours wins
            them all). Provider order is desc-by-initOrder, so a
            higher number => earlier.
        -->
        <provider
            android:name="io.ssemaj.deviceintelligence.internal.DeviceIntelligenceInitProvider"
            android:authorities="${applicationId}.io.ssemaj.deviceintelligence.InitProvider"
            android:exported="false"
            android:initOrder="2147483647" />
    </application>

</manifest>
