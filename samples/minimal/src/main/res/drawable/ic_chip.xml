<?xml version="1.0" encoding="utf-8"?>
<!-- Brand mark: chip + 3 concentric scan rings; matches the launcher monochrome.
     24x24 viewport, single-colour stroke fills tinted at runtime via imageTintList. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?android:attr/colorForeground">
    <!-- Pins (top, bottom, left, right) -->
    <path android:fillColor="#FFFFFF" android:pathData="M8,3 h1.5 v2 h-1.5 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M11.25,3 h1.5 v2 h-1.5 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M14.5,3 h1.5 v2 h-1.5 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M8,19 h1.5 v2 h-1.5 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M11.25,19 h1.5 v2 h-1.5 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M14.5,19 h1.5 v2 h-1.5 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M3,8 h2 v1.5 h-2 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M3,11.25 h2 v1.5 h-2 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M3,14.5 h2 v1.5 h-2 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M19,8 h2 v1.5 h-2 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M19,11.25 h2 v1.5 h-2 z" />
    <path android:fillColor="#FFFFFF" android:pathData="M19,14.5 h2 v1.5 h-2 z" />
    <!-- Chip body outline -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:pathData="M7,9 a2,2 0 0 1 2,-2 h6 a2,2 0 0 1 2,2 v6 a2,2 0 0 1 -2,2 h-6 a2,2 0 0 1 -2,-2 z" />
    <!-- Concentric scan rings -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.1"
        android:fillColor="#00000000"
        android:pathData="M12,9.5 a2.5,2.5 0 1 1 -0.01,0 z" />
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.9"
        android:fillColor="#00000000"
        android:pathData="M12,11 a1,1 0 1 1 -0.01,0 z" />
</vector>
